# Copy this file to ".env" and fill in your own values.
# Never commit your real .env file to GitHub!

# Your Discord bot's token (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord application's Client ID (Discord Developer Portal -> General Information)
CLIENT_ID=your_discord_application_client_id_here

# The ID of the Discord server (guild) you're running the bot in
# (right-click your server icon in Discord -> Copy Server ID)
GUILD_ID=your_discord_server_id_here

# Your TMDb API key (v3 auth) from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
